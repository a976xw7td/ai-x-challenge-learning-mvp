# ==========================================
# AI+X Challenge Learning MVP — 环境变量
# ==========================================
# 复制此文件为 .env.local 并填入真实值
# cp .env.example .env.local
# ==========================================

# --- 飞书多维表 ---
# 飞书开发者后台 → 应用 → 凭证与基础信息
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 飞书多维表的 app_token（多维表 URL 中 /base/ 后面那段）
FEISHU_APP_TOKEN=

# 各子表 ID（从飞书多维表 URL 中 /table/ 后面那段）
FEISHU_STUDENTS_TABLE_ID=tblZNoZuykeoSLZL
FEISHU_CHALLENGES_TABLE_ID=tbl63XxcXrFa1Wob
FEISHU_SUBMISSIONS_TABLE_ID=tblk0W13dUdeJCqr
FEISHU_EVALUATIONS_TABLE_ID=tbljVBBaMPeJ7biJ
FEISHU_PORTFOLIO_TABLE_ID=tblJQGf5W3og3gux

# Agent 阶段新增表
FEISHU_AUDITLOGS_TABLE_ID=tbl31l2XhXDMOB7K
FEISHU_INBOX_TABLE_ID=tbllCuyN67TyCBcm

# --- 飞书 Bot 通知 ---
# 班级群聊 chat_id（用于发布 Challenge 群公告，未配置则跳过）
FEISHU_CLASS_CHAT_ID=

# --- 登录认证 ---
# Session 签名密钥（生成方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"）
SESSION_SECRET=

# 教师 ID 列表（逗号分隔，这些 student_id 登录时 role=teacher）
TEACHER_IDS=

# --- GitHub ---
# GitHub Personal Access Token（Settings → Developer settings → Tokens）
# 权限需要：repo（私有仓库）或 public_repo（仅公开仓库）
GITHUB_TOKEN=

# --- AI 评审 ---
# DeepSeek API（https://platform.deepseek.com）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 可选：OpenAI 兼容 API（不配则用 DeepSeek）
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- 课程内容 ---
# 平台内容（知识库+文档）来源。不配则用 public/platform-content.json
# 配了则从远程 URL 读取（如 GitHub raw），5 分钟缓存
# PLATFORM_CONTENT_URL=https://raw.githubusercontent.com/xxx/xxx/main/content.json
